{
  "name": "@hiero-hackers/hiero-checkout",
  "version": "0.0.1",
  "private": true,
  "description": "Payer-facing checkout for Hiero payments \u2014 a static page that turns a payment QR or link into a wallet action and a live paid-check. No backend, no keys, no analytics.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build && node scripts/check-dist.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage && vite build && node scripts/check-dist.mjs",
    "lint": "eslint src test scripts",
    "format": "prettier --write src test scripts index.html *.md",
    "format:check": "prettier --check src test scripts index.html *.md",
    "screenshots": "node scripts/screenshots.mjs",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.11.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@hashgraph/hedera-wallet-connect": "^2.1.3",
    "@hiero-hackers/hiero-payment-requests": "^0.1.0",
    "@hiero-hackers/hiero-receipts": "^0.1.0",
    "buffer": "^6.0.3"
  }
}
